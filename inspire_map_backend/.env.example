# 《灵感经纬》环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ==================== 基础配置 ====================
ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ==================== 数据库配置 ====================
# PostgreSQL 连接字符串
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/inspire_map
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ==================== Redis 配置 ====================
# Redis 连接字符串
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=604800

# ==================== 安全配置 ====================
# JWT 密钥 (生产环境必须设置！否则每次重启随机生成，旧 Token 失效)
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==================== AI 大模型配置 ====================
# 选择 LLM 提供商: deepseek / qwen
LLM_PROVIDER=deepseek

# DeepSeek API
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 阿里云百炼 (通义千问) API
QWEN_API_KEY=your-qwen-api-key
QWEN_API_BASE=https://dashscope.aliyuncs.com/api/v1

# AI 请求降本配置
ENABLE_AI_CACHE=true
AI_CACHE_TTL=604800
MAX_AI_CONTEXT_ROUNDS=5

# ==================== 向量数据库配置 ====================
# ChromaDB 配置
CHROMA_PERSIST_DIRECTORY=./chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ==================== 高德地图配置 ====================
AMAP_API_KEY=your-amap-api-key
AMAP_API_SECRET=your-amap-api-secret

# ==================== 内容安全 ====================
CONTENT_AUDIT_ENABLED=true

# ==================== CORS 配置 ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5000
